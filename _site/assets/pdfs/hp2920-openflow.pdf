      <rdf:Description rdf:about=""
            xmlns:dc="http://purl.org/dc/elements/1.1/">
         <dc:format>application/pdf</dc:format>
         <dc:title>
            <rdf:Alt>
               <rdf:li xml:lang="x-default">Prepare for software-defined networking: Build the foundation for SDN with OpenFlowŌĆĢBusiness white paper (US English)</rdf:li>
            </rdf:Alt>
         </dc:title>
         <dc:creator>
            <rdf:Seq>
               <rdf:li>steve.brar@hp.com</rdf:li>
            </rdf:Seq>
         </dc:creator>
         <dc:description>
            <rdf:Alt>
               <rdf:li xml:lang="x-default">Virtualized networks, enabled by OpenFlow, simplify the challenge of moving virtual workloads across data centers. Network bandwidth can be automatically expanded to meet dynamically changing application and service requirements.</rdf:li>
            </rdf:Alt>
         </dc:description>
         <dc:subject>
