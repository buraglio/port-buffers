               <rdf:li>network intelligence</rdf:li>
               <rdf:li>network services</rdf:li>
               <rdf:li>orchestration tools</rdf:li>
               <rdf:li>business application</rdf:li>
               <rdf:li>control layer</rdf:li>
               <rdf:li>virtualization</rdf:li>
               <rdf:li>wireless and wired LANs</rdf:li>
            </rdf:Bag>
         </dc:subject>
      </rdf:Description>
