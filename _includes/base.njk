<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- set pageTitle = title if (title and title != site.name) else "" -%}
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.name }}">
  <meta name="twitter:description" content="{{ description or site.description }}">

  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>

<header class="site-header">
  <a href="/" class="site-title">Packet Buffer Reference</a>
  <nav class="site-nav">
    <a href="/">Table</a>
    <a href="/summary/">Summary</a>
    <a href="/contributing/">Contributing</a>
    <details class="nav-dropdown">
      <summary>Concepts</summary>
      <div class="nav-dropdown-menu">
        <a href="/concepts/buffer-fundamentals/">Buffer Fundamentals</a>
        <a href="/concepts/microburst/">Microbursts</a>
        <a href="/concepts/trident-plus/">Trident+</a>
        <a href="/concepts/trident-ii/">Trident II</a>
        <a href="/concepts/broadcom-trident3/">Trident 3</a>
        <a href="/concepts/broadcom-trident4/">Trident 4</a>
        <a href="/concepts/broadcom-tomahawk4/">Tomahawk 4</a>
        <a href="/concepts/broadcom-tomahawk5/">Tomahawk 5</a>
        <a href="/concepts/broadcom-jericho/">Jericho / Jericho 2</a>
        <a href="/concepts/broadcom-jericho3/">Jericho 3</a>
        <a href="/concepts/broadcom-jericho4/">Jericho 4</a>
        <a href="/concepts/deep-buffer/">Deep Buffer</a>
        <a href="/concepts/nokia-sr-platform/">Nokia SR (FP4/FP5)</a>
        <a href="/concepts/nokia-access-agg/">Nokia Access/Agg</a>
      </div>
    </details>
  </nav>
</header>

<main class="site-main">
  {{ content | safe }}
</main>

<footer class="site-footer">
  Source: Jim Warner, UCSC (archived 2014). Information is by rumor, innuendo, and extrapolation.
  Manufacturers rarely publish packet buffer data in their data sheets.
</footer>

</body>
</html>
